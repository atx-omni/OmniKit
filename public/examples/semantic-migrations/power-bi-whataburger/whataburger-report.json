{
  "$schema": "https://developer.microsoft.com/json-schemas/fabric/item/report/definition/report/1.0.0/schema.json",
  "id": "pbi-report-whata-dashboard",
  "name": "WhataDashboard",
  "datasetId": "pbi-model-whataburger",
  "pages": [
    {
      "id": "page-executive-kpis",
      "name": "Executive KPIs",
      "filters": [{ "name": "business_date" }],
      "visuals": [{ "id": "visual-executive-kpis", "name": "Executive KPIs", "visualType": "card", "fields": [{ "queryRef": "Daily Grill Report.total_revenue" }, { "queryRef": "Daily Grill Report.orders" }, { "queryRef": "Daily Grill Report.discount_rate" }] }]
    },
    {
      "id": "page-weekly-trend",
      "name": "Weekly Revenue Trend",
      "filters": [{ "name": "business_date" }],
      "visuals": [{ "id": "visual-weekly-trend", "name": "Weekly Revenue Trend", "visualType": "lineChart", "fields": [{ "queryRef": "Daily Grill Report.business_date" }, { "queryRef": "Daily Grill Report.total_revenue" }, { "queryRef": "Daily Grill Report.orders" }] }]
    },
    {
      "id": "page-location-performance",
      "name": "Location Performance",
      "filters": [{ "name": "region" }],
      "visuals": [{ "id": "visual-location-performance", "name": "Location Performance", "visualType": "clusteredBarChart", "fields": [{ "queryRef": "Whataburger Locations.location_name" }, { "queryRef": "Whataburger Locations.territory" }, { "queryRef": "Daily Grill Report.total_revenue" }] }]
    },
    {
      "id": "page-deals-discounts",
      "name": "Deals & Discounts",
      "filters": [{ "name": "business_date" }],
      "visuals": [{ "id": "visual-deals-discounts", "name": "Deals & Discounts", "visualType": "tableEx", "fields": [{ "queryRef": "Daily Grill Report.business_date" }, { "queryRef": "Daily Grill Report.discounts" }, { "queryRef": "Daily Grill Report.discount_rate" }] }]
    },
    {
      "id": "page-profitability",
      "name": "Profitability by Menu Category",
      "filters": [{ "name": "category" }],
      "visuals": [{ "id": "visual-profitability", "name": "Profitability by Menu Category", "visualType": "barChart", "fields": [{ "queryRef": "Menu Item P&L.category" }, { "queryRef": "Menu Item P&L.net_revenue" }, { "queryRef": "Menu Item P&L.margin_pct" }] }]
    },
    {
      "id": "page-channel-mix",
      "name": "Order Channel Mix",
      "filters": [{ "name": "business_date" }],
      "visuals": [{ "id": "visual-channel-mix", "name": "Order Channel Mix", "visualType": "pieChart", "fields": [{ "queryRef": "Daily Grill Report.order_channel" }, { "queryRef": "Daily Grill Report.total_revenue" }, { "queryRef": "Daily Grill Report.orders" }] }]
    }
  ]
}
