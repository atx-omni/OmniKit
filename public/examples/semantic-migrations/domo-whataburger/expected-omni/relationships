- join_from_view: whataburger__daily_grill_report
  join_to_view: whataburger__whataburger_locations
  join_type: always_left
  on_sql: ${whataburger__daily_grill_report.store_number} = ${whataburger__whataburger_locations.store_number}
  relationship_type: many_to_one
- join_from_view: whataburger__daily_grill_report
  join_to_view: whataburger__bag_tickets
  join_type: always_left
  on_sql: ${whataburger__daily_grill_report.order_id} = ${whataburger__bag_tickets.order_id}
  relationship_type: one_to_one
- join_from_view: whataburger__bag_tickets
  join_to_view: whataburger__grill_slips
  join_type: always_left
  on_sql: ${whataburger__bag_tickets.order_id} = ${whataburger__grill_slips.order_id}
  relationship_type: one_to_many
- join_from_view: whataburger__grill_slips
  join_to_view: whataburger__menu_board
  join_type: always_left
  on_sql: ${whataburger__grill_slips.menu_item_id} = ${whataburger__menu_board.menu_item_id}
  relationship_type: many_to_one
- join_from_view: whataburger__menu_board
  join_to_view: whataburger__menu_item_pnl
  join_type: always_left
  on_sql: ${whataburger__menu_board.menu_item_id} = ${whataburger__menu_item_pnl.menu_item_id}
  relationship_type: one_to_one
