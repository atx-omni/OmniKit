{
  "workbookId": "synthetic-whata-workbook",
  "datasets": [
    {
      "id": "whata_sales",
      "name": "Whata Sales",
      "columns": [
        { "id": "order_id", "name": "Order ID", "type": "text" },
        { "id": "business_date", "name": "Business Date", "type": "date" },
        { "id": "store_number", "name": "Store Number", "type": "integer" },
        { "id": "net_sales", "name": "Net Sales", "type": "number" }
      ],
      "calculations": [{ "id": "total_revenue", "name": "Total Revenue", "formula": "Sum([Net Sales])", "aggregation": "sum" }]
    },
    {
      "id": "whata_locations",
      "name": "Whata Locations",
      "columns": [{ "id": "location_name", "name": "Location Name", "type": "text" }],
      "calculations": []
    }
  ],
  "relationships": [{ "from": "Whata Sales", "to": "Whata Locations", "joinType": "many_to_one", "on": "Whata Sales.Store Number = Whata Locations.Store Number" }],
  "pages": [{ "id": "page-1", "name": "WhataDashboard", "filterName": "Business Date" }],
  "elements": [{ "id": "element-1", "name": "Revenue by Location", "fieldName": "Location Name", "metricName": "Total Revenue", "filterName": "Business Date", "type": "bar" }]
}
