{
  "id": "42",
  "title": "Exec KPIs",
  "url": "/dashboards/42",
  "dashboard_filters": [
    {"name": "Created Date", "dimension": "order_items.created_date", "default_value": "30 days", "type": "field_filter"}
  ],
  "dashboard_layouts": [
    {"dashboard_layout_components": [
      {"dashboard_element_id": "e1", "row": 0, "column": 0, "width": 12, "height": 6},
      {"dashboard_element_id": "e2", "row": 0, "column": 12, "width": 12, "height": 6},
      {"dashboard_element_id": "e3", "row": 6, "column": 0, "width": 24, "height": 4}
    ]}
  ],
  "dashboard_elements": [
    {
      "id": "e1", "type": "vis", "title": "Revenue by Month",
      "query": {
        "model": "ecommerce", "view": "order_items",
        "fields": ["order_items.created_month", "order_items.total_revenue"],
        "filters": {"order_items.status": "complete"},
        "sorts": ["order_items.created_month"], "pivots": null, "limit": "500"
      },
      "vis_config": {"type": "looker_column"}
    },
    {
      "id": "e2", "type": "vis", "title": "Total Revenue",
      "query": {"model": "ecommerce", "view": "order_items", "fields": ["order_items.total_revenue"]},
      "vis_config": {"type": "single_value"}
    },
    {"id": "e3", "type": "text", "title": "Notes", "body_text": "Exec summary dashboard"},
    {
      "id": "e4", "type": "vis", "title": "Merged", "merge_result_id": "abc",
      "query": {"view": "x", "fields": ["x.a"]}, "vis_config": {"type": "looker_grid"}
    }
  ]
}
