{
  "id": "professional-dashboard",
  "title": "Example operations overview",
  "url": "/dashboards/professional-dashboard",
  "folder": { "id": "shared", "name": "Shared analytics" },
  "dashboard_filters": [
    { "id": "date-filter", "name": "Date", "dimension": "example_orders.created_date", "default_value": "30 days", "type": "date_filter" },
    { "id": "status-filter", "name": "Status", "dimension": "example_orders.status", "default_value": "completed", "type": "field_filter" }
  ],
  "dashboard_layouts": [
    {
      "dashboard_layout_components": [
        { "dashboard_element_id": "tile-1", "row": 0, "column": 0, "width": 16, "height": 6 },
        { "dashboard_element_id": "tile-2", "row": 0, "column": 16, "width": 8, "height": 6 },
        { "dashboard_element_id": "tile-3", "row": 6, "column": 0, "width": 24, "height": 3 }
      ]
    }
  ],
  "dashboard_elements": [
    {
      "id": "tile-1",
      "title": "Orders by segment",
      "type": "vis",
      "vis_config": { "type": "looker_column", "stacking": "normal", "show_value_labels": true },
      "result_maker": {
        "query": {
          "id": "query-1",
          "model": "example_model",
          "view": "example_orders",
          "fields": ["example_orders.created_month", "example_orders.order_count"],
          "filters": { "example_orders.status": "completed" },
          "filter_expression": "${example_orders.order_count} > 0",
          "sorts": ["example_orders.created_month desc"],
          "pivots": ["example_accounts.segment"],
          "hidden_fields": ["example_orders.order_count"],
          "dynamic_fields": "[{\"category\":\"dimension\",\"dimension\":\"segment_group\",\"label\":\"Segment group\",\"expression\":\"case(when(${example_accounts.segment}=\\\"enterprise\\\",\\\"Priority\\\"),\\\"Standard\\\")\"},{\"category\":\"measure\",\"measure\":\"filtered_orders\",\"label\":\"Filtered orders\",\"based_on\":\"example_orders.order_count\",\"filters\":{\"example_orders.status\":\"completed\"}}]",
          "limit": 500
        },
        "filterables": [
          { "listen": { "Date": "example_orders.created_date", "Status": "example_orders.status" } }
        ]
      }
    },
    {
      "id": "tile-2",
      "title": "Merged comparison",
      "merge_result_id": "merge-1",
      "vis_config": { "type": "looker_line" }
    },
    {
      "id": "tile-3",
      "title": "Methodology",
      "type": "text",
      "body_text": "Synthetic migration fixture for deterministic validation."
    }
  ]
}
