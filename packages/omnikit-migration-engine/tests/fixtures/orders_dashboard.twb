<?xml version='1.0' encoding='utf-8' ?>
<workbook>
  <datasources>
    <datasource caption='orders' name='federated.abc123' version='18.1'>
      <connection class='snowflake' dbname='ANALYTICS'>
        <relation name='ORDERS' table='[PUBLIC].[ORDERS]' type='table' />
      </connection>
      <column caption='Region' datatype='string' name='[Region]' role='dimension' type='nominal' />
      <column caption='Amount' datatype='real' name='[Amount]' role='measure' type='quantitative' />
      <column caption='Created At' datatype='datetime' name='[Created At]' role='dimension' type='ordinal' />
    </datasource>
  </datasources>
  <worksheets>
    <worksheet name='Sales by Region'>
      <table>
        <view>
          <datasources>
            <datasource caption='orders' name='federated.abc123' />
          </datasources>
          <datasource-dependencies datasource='federated.abc123'>
            <column caption='Region' datatype='string' name='[Region]' role='dimension' type='nominal' />
            <column caption='Amount' datatype='real' name='[Amount]' role='measure' type='quantitative' />
          </datasource-dependencies>
        </view>
        <rows>[federated.abc123].[none:Region:nk]</rows>
        <cols>[federated.abc123].[sum:Amount:qk]</cols>
        <panes>
          <pane>
            <mark class='Bar' />
          </pane>
        </panes>
      </table>
    </worksheet>
    <worksheet name='Orders Over Time'>
      <table>
        <view>
          <datasources>
            <datasource caption='orders' name='federated.abc123' />
          </datasources>
          <datasource-dependencies datasource='federated.abc123'>
            <column caption='Created At' datatype='datetime' name='[Created At]' role='dimension' type='ordinal' />
            <column caption='Amount' datatype='real' name='[Amount]' role='measure' type='quantitative' />
          </datasource-dependencies>
        </view>
        <rows>[federated.abc123].[sum:Amount:qk]</rows>
        <cols>[federated.abc123].[none:Created At:nk]</cols>
        <panes>
          <pane>
            <mark class='Line' />
          </pane>
        </panes>
      </table>
    </worksheet>
  </worksheets>
  <dashboards>
    <dashboard name='Overview'>
      <size maxheight='800' maxwidth='1200' minheight='800' minwidth='1200' />
      <zones>
        <zone h='100000' id='1' type-v2='layout-basic' w='100000' x='0' y='0'>
          <zone h='90000' id='2' name='Sales by Region' w='50000' x='0' y='0' />
          <zone h='90000' id='3' name='Orders Over Time' w='50000' x='50000' y='0' />
          <zone h='5000' id='4' type-v2='text' w='100000' x='0' y='90000'>
            <formatted-text>
              <run>Dashboard notes</run>
            </formatted-text>
          </zone>
          <zone h='5000' id='5' type-v2='filter' name='Region Filter' w='100000' x='0' y='95000' />
        </zone>
      </zones>
    </dashboard>
  </dashboards>
</workbook>
