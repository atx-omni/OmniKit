- join_from_view: northstar__daily_grill_report
  join_to_view: northstar__northstar_locations
  join_type: always_left
  on_sql: ${northstar__daily_grill_report.store_number} = ${northstar__northstar_locations.store_number}
  relationship_type: many_to_one
- join_from_view: northstar__daily_grill_report
  join_to_view: northstar__bag_tickets
  join_type: always_left
  on_sql: ${northstar__daily_grill_report.order_id} = ${northstar__bag_tickets.order_id}
  relationship_type: one_to_one
- join_from_view: northstar__bag_tickets
  join_to_view: northstar__grill_slips
  join_type: always_left
  on_sql: ${northstar__bag_tickets.order_id} = ${northstar__grill_slips.order_id}
  relationship_type: one_to_many
- join_from_view: northstar__grill_slips
  join_to_view: northstar__menu_board
  join_type: always_left
  on_sql: ${northstar__grill_slips.menu_item_id} = ${northstar__menu_board.menu_item_id}
  relationship_type: many_to_one
- join_from_view: northstar__menu_board
  join_to_view: northstar__menu_item_pnl
  join_type: always_left
  on_sql: ${northstar__menu_board.menu_item_id} = ${northstar__menu_item_pnl.menu_item_id}
  relationship_type: one_to_one
