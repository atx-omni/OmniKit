{
  "schemaVersion": "omnikit.dashboard-build.v1",
  "targetName": "NorthstarDashboard",
  "topic": "NorthstarTopic",
  "description": "Expected dashboard intent reconstructed from the six Domo Cards.",
  "tiles": [
    { "title": "Executive KPIs", "visualType": "kpi", "fields": ["northstar__daily_grill_report.total_revenue", "northstar__daily_grill_report.orders", "northstar__daily_grill_report.discount_rate"] },
    { "title": "Weekly Revenue Trend", "visualType": "line", "fields": ["northstar__daily_grill_report.business_date", "northstar__daily_grill_report.total_revenue"] },
    { "title": "Location Performance", "visualType": "bar", "fields": ["northstar__northstar_locations.location_name", "northstar__northstar_locations.territory", "northstar__daily_grill_report.total_revenue"] },
    { "title": "Deals & Discounts", "visualType": "table", "fields": ["northstar__daily_grill_report.business_date", "northstar__daily_grill_report.discounts", "northstar__daily_grill_report.discount_rate"] },
    { "title": "Profitability by Menu Category", "visualType": "bar", "fields": ["northstar__menu_item_pnl.category", "northstar__menu_item_pnl.net_revenue", "northstar__menu_item_pnl.margin_pct"] },
    { "title": "Order Channel Mix", "visualType": "pie", "fields": ["northstar__daily_grill_report.order_channel", "northstar__daily_grill_report.total_revenue"] }
  ],
  "validationAssertions": [
    "All six tiles are created on NorthstarTopic.",
    "Total Revenue, Orders, and Margin Pct return non-null values.",
    "Location Performance can group by territory without an out-of-topic error.",
    "The dashboard has no missing-field or missing-join errors."
  ]
}
