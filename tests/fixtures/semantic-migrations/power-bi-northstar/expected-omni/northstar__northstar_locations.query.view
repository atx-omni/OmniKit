label: Northstar Locations
description: Simulated store and Texas territory attributes for the Northstar-style demo.
sql: |
  SELECT
    STORE_NUMBER AS store_number,
    CONCAT(STORE_CITY, ' #', STORE_NUMBER) AS location_name,
    STORE_CITY AS city,
    STORE_STATE AS state,
    CASE WHEN STORE_CITY IN ('San Antonio', 'Houston') THEN 'South Texas' ELSE 'North Texas' END AS territory,
    DISTRIBUTION_REGION AS region
  FROM raw.store_restaurants
dimensions:
  store_number: {}
  location_name: {}
  city: {}
  state: {}
  territory: {}
  region: {}
measures:
  location_count:
    sql: ${store_number}
    aggregate_type: count_distinct
