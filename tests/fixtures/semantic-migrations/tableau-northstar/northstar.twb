<?xml version="1.0" encoding="utf-8"?>
<workbook version="2024.1">
  <datasources>
    <datasource name="northstar_sales" caption="Northstar Sales">
      <connection class="snowflake">
        <relation type="join" join="left">
          <relation name="northstar_sales" table="[analytics].[northstar_sales]" type="table" />
          <relation name="northstar_locations" table="[analytics].[northstar_locations]" type="table" />
          <clause type="join"><expression op="=" left="[northstar_sales].[store_number]" right="[northstar_locations].[store_number]" /></clause>
        </relation>
      </connection>
      <column name="[Order ID]" caption="Order ID" datatype="string" role="dimension" />
      <column name="[Business Date]" caption="Business Date" datatype="date" role="dimension" />
      <column name="[Store Number]" caption="Store Number" datatype="integer" role="dimension" />
      <column name="[Location Name]" caption="Location Name" datatype="string" role="dimension" />
      <column name="[Net Sales]" caption="Net Sales" datatype="real" role="measure" default-aggregation="Sum" />
      <column name="[Average Ticket]" caption="Average Ticket" datatype="real" role="measure">
        <calculation class="tableau" formula="SUM([Net Sales]) / COUNTD([Order ID])" />
      </column>
    </datasource>
  </datasources>
  <dashboards>
    <dashboard name="NorthstarDashboard">
      <zone name="Revenue by Location" field="[Location Name]" column="[Net Sales]" />
      <filter field="[Business Date]" />
    </dashboard>
  </dashboards>
</workbook>
