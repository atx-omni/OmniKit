{
  "cubes": [
    {
      "id": "MSTR-CUBE-DAILY-GRILL",
      "name": "Daily Grill Report",
      "attributes": [
        { "id": "A-ORDER-ID", "name": "order_id", "type": "attribute" },
        { "id": "A-BUSINESS-DATE", "name": "business_date", "type": "attribute" },
        { "id": "A-STORE-NUMBER", "name": "store_number", "type": "attribute" },
        { "id": "A-ORDER-CHANNEL", "name": "order_channel", "type": "attribute" },
        { "id": "A-DAYPART", "name": "daypart", "type": "attribute" },
        { "id": "A-GROSS-SALES", "name": "gross_sales", "type": "attribute" },
        { "id": "A-DISCOUNTS", "name": "discounts", "type": "attribute" },
        { "id": "A-NET-SALES", "name": "net_sales", "type": "attribute" },
        { "id": "A-ORDER-COUNT", "name": "order_count", "type": "attribute" },
        { "id": "A-UNITS-SOLD", "name": "units_sold", "type": "attribute" },
        { "id": "A-ADD-ON-REVENUE", "name": "add_on_revenue", "type": "attribute" }
      ],
      "metrics": [
        { "id": "M-TOTAL-REVENUE", "name": "total_revenue", "formula": "Sum(net_sales)" },
        { "id": "M-ORDERS", "name": "orders", "formula": "Count(Distinct order_id)" },
        { "id": "M-AVERAGE-BAG-SIZE", "name": "average_bag_size", "formula": "Sum(net_sales) / NullToZero(Count(Distinct order_id))" },
        { "id": "M-ATTACH-RATE", "name": "attach_rate", "formula": "Sum(add_on_revenue) / NullToZero(Sum(net_sales))" },
        { "id": "M-DISCOUNT-RATE", "name": "discount_rate", "formula": "Sum(discounts) / NullToZero(Sum(gross_sales))" }
      ]
    },
    {
      "id": "MSTR-CUBE-LOCATIONS",
      "name": "Northstar Locations",
      "attributes": [
        { "id": "A-STORE-NUMBER", "name": "store_number", "type": "attribute" },
        { "id": "A-LOCATION-NAME", "name": "location_name", "type": "attribute" },
        { "id": "A-CITY", "name": "city", "type": "attribute" },
        { "id": "A-STATE", "name": "state", "type": "attribute" },
        { "id": "A-TERRITORY", "name": "territory", "type": "attribute" },
        { "id": "A-REGION", "name": "region", "type": "attribute" }
      ],
      "metrics": [{ "id": "M-LOCATION-COUNT", "name": "location_count", "formula": "Count(Distinct store_number)" }]
    },
    {
      "id": "MSTR-CUBE-BAG-TICKETS",
      "name": "Bag Tickets",
      "attributes": [
        { "id": "A-ORDER-ID", "name": "order_id", "type": "attribute" },
        { "id": "A-STORE-NUMBER", "name": "store_number", "type": "attribute" },
        { "id": "A-BUSINESS-DATE", "name": "business_date", "type": "attribute" },
        { "id": "A-ITEM-COUNT", "name": "item_count", "type": "attribute" },
        { "id": "A-TICKET-TOTAL", "name": "ticket_total", "type": "attribute" },
        { "id": "A-BAG-SIZE", "name": "bag_size", "type": "attribute" },
        { "id": "A-ORDER-CHANNEL", "name": "order_channel", "type": "attribute" }
      ],
      "metrics": [{ "id": "M-ITEMS-PER-BAG", "name": "items_per_bag", "formula": "Sum(item_count) / NullToZero(Count(Distinct order_id))" }]
    },
    {
      "id": "MSTR-CUBE-GRILL-SLIPS",
      "name": "Grill Slips",
      "attributes": [
        { "id": "A-ORDER-ID", "name": "order_id", "type": "attribute" },
        { "id": "A-MENU-ITEM-ID", "name": "menu_item_id", "type": "attribute" },
        { "id": "A-CATEGORY", "name": "category", "type": "attribute" },
        { "id": "A-QUANTITY", "name": "quantity", "type": "attribute" },
        { "id": "A-LINE-REVENUE", "name": "line_revenue", "type": "attribute" },
        { "id": "A-STATION-NAME", "name": "station_name", "type": "attribute" },
        { "id": "A-PREP-SECONDS", "name": "prep_seconds", "type": "attribute" }
      ],
      "metrics": [{ "id": "M-UNITS-SOLD", "name": "units_sold", "formula": "Sum(quantity)" }]
    },
    {
      "id": "MSTR-CUBE-MENU-BOARD",
      "name": "The Menu Board",
      "attributes": [
        { "id": "A-MENU-ITEM-ID", "name": "menu_item_id", "type": "attribute" },
        { "id": "A-ITEM-NAME", "name": "item_name", "type": "attribute" },
        { "id": "A-CATEGORY", "name": "category", "type": "attribute" },
        { "id": "A-MENU-GROUP", "name": "menu_group", "type": "attribute" },
        { "id": "A-LIST-PRICE", "name": "list_price", "type": "attribute" },
        { "id": "A-ACTIVE-FLAG", "name": "active_flag", "type": "attribute" }
      ],
      "metrics": [{ "id": "M-ACTIVE-MENU-ITEMS", "name": "active_menu_items", "formula": "Count(Distinct If(active_flag = 'Y', menu_item_id, Null))" }]
    },
    {
      "id": "MSTR-CUBE-MENU-PNL",
      "name": "Menu Item P&L",
      "attributes": [
        { "id": "A-MENU-ITEM-ID", "name": "menu_item_id", "type": "attribute" },
        { "id": "A-CATEGORY", "name": "category", "type": "attribute" },
        { "id": "A-UNITS-SOLD", "name": "units_sold", "type": "attribute" },
        { "id": "A-GROSS-REVENUE", "name": "gross_revenue", "type": "attribute" },
        { "id": "A-DISCOUNTS", "name": "discounts", "type": "attribute" },
        { "id": "A-NET-REVENUE", "name": "net_revenue", "type": "attribute" },
        { "id": "A-FOOD-COST", "name": "food_cost", "type": "attribute" },
        { "id": "A-GROSS-MARGIN", "name": "gross_margin", "type": "attribute" }
      ],
      "metrics": [
        { "id": "M-TOTAL-GROSS-MARGIN", "name": "total_gross_margin", "formula": "Sum(gross_margin)" },
        { "id": "M-MARGIN-PCT", "name": "margin_pct", "formula": "Sum(gross_margin) / NullToZero(Sum(net_revenue))" },
        { "id": "M-TOTAL-FOOD-COST", "name": "total_food_cost", "formula": "Sum(food_cost)" }
      ]
    }
  ],
  "relationships": [
    { "from": "Daily Grill Report", "to": "Northstar Locations", "cardinality": "many_to_one", "expression": "Daily Grill Report.store_number = Northstar Locations.store_number" },
    { "from": "Daily Grill Report", "to": "Bag Tickets", "cardinality": "one_to_one", "expression": "Daily Grill Report.order_id = Bag Tickets.order_id" },
    { "from": "Daily Grill Report", "to": "Grill Slips", "cardinality": "one_to_many", "expression": "Daily Grill Report.order_id = Grill Slips.order_id" },
    { "from": "Grill Slips", "to": "The Menu Board", "cardinality": "many_to_one", "expression": "Grill Slips.menu_item_id = The Menu Board.menu_item_id" },
    { "from": "Grill Slips", "to": "Menu Item P&L", "cardinality": "many_to_one", "expression": "Grill Slips.menu_item_id = Menu Item P&L.menu_item_id" }
  ]
}
