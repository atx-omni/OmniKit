{
  "exportType": "domo-beast-mode-search-results",
  "beastModes": [
    { "id": "beast-total-revenue", "name": "Total Revenue", "dataSourceId": "domo-ds-daily-grill", "formula": "SUM(`Net Sales`)", "dataType": "DECIMAL" },
    { "id": "beast-orders", "name": "Orders", "dataSourceId": "domo-ds-daily-grill", "formula": "COUNT(DISTINCT `Order ID`)", "dataType": "LONG" },
    { "id": "beast-average-bag-size", "name": "Average Bag Size", "dataSourceId": "domo-ds-daily-grill", "formula": "SUM(`Net Sales`) / NULLIF(COUNT(DISTINCT `Order ID`), 0)", "dataType": "DECIMAL" },
    { "id": "beast-attach-rate", "name": "Attach Rate", "dataSourceId": "domo-ds-daily-grill", "formula": "SUM(`Add-On Revenue`) / NULLIF(SUM(`Net Sales`), 0)", "dataType": "DECIMAL" },
    { "id": "beast-discount-rate", "name": "Discount Rate", "dataSourceId": "domo-ds-daily-grill", "formula": "SUM(`Discounts`) / NULLIF(SUM(`Gross Sales`), 0)", "dataType": "DECIMAL" },
    { "id": "beast-location-count", "name": "Location Count", "dataSourceId": "domo-ds-locations", "formula": "COUNT(DISTINCT `Store Number`)", "dataType": "LONG" },
    { "id": "beast-items-per-bag", "name": "Items per Bag", "dataSourceId": "domo-ds-bag-tickets", "formula": "SUM(`Item Count`) / NULLIF(COUNT(DISTINCT `Order ID`), 0)", "dataType": "DECIMAL" },
    { "id": "beast-units-sold", "name": "Units Sold", "dataSourceId": "domo-ds-grill-slips", "formula": "SUM(`Quantity`)", "dataType": "LONG" },
    { "id": "beast-active-menu-items", "name": "Active Menu Items", "dataSourceId": "domo-ds-menu-board", "formula": "COUNT(DISTINCT CASE WHEN `Active Flag` = 'Y' THEN `Menu Item ID` END)", "dataType": "LONG" },
    { "id": "beast-total-gross-margin", "name": "Total Gross Margin", "dataSourceId": "domo-ds-menu-item-pnl", "formula": "SUM(`Gross Margin`)", "dataType": "DECIMAL" },
    { "id": "beast-margin-pct", "name": "Margin Pct", "dataSourceId": "domo-ds-menu-item-pnl", "formula": "SUM(`Gross Margin`) / NULLIF(SUM(`Net Revenue`), 0)", "dataType": "DECIMAL" },
    { "id": "beast-total-food-cost", "name": "Total Food Cost", "dataSourceId": "domo-ds-menu-item-pnl", "formula": "SUM(`Food Cost`)", "dataType": "DECIMAL" }
  ]
}
