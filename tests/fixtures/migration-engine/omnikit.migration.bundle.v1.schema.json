        "contract_version": {
          "title": "Contract Version",
          "type": "string"
        },
        "dashboard_ids": {
          "items": {
            "type": "string"
          },
          "title": "Dashboard Ids",
          "type": "array"
        },
        "dependencies": {
          "items": {
            "$ref": "#/$defs/AcquisitionDependencyIR"
          },
          "title": "Dependencies",
          "type": "array"
        },
        "dependency_closure_status": {
          "default": "not_evaluated",
          "enum": [
            "not_evaluated",
            "not_applicable",
            "complete",
            "partial",
            "blocked"
          ],
          "title": "Dependency Closure Status",
          "type": "string"
        },
        "diagnostics": {
          "items": {
            "type": "string"
          },
          "title": "Diagnostics",
          "type": "array"
        },
        "look_ids": {
          "items": {
            "type": "string"
          },
          "title": "Look Ids",
          "type": "array"
        },
        "mode": {
          "default": "unknown",
          "enum": [
            "manual",
            "api",
            "unknown"
          ],
          "title": "Mode",
          "type": "string"
        },
        "project_ids": {
          "items": {
            "type": "string"
          },
          "title": "Project Ids",
          "type": "array"
        },
        "query_ids": {
          "items": {
            "type": "string"
          },
          "title": "Query Ids",
          "type": "array"
        },
        "required_files": {
          "items": {
            "type": "string"
          },
          "title": "Required Files",
          "type": "array"
        },
        "saved_look_coverage": {
          "default": "not_evaluated",
          "enum": [
            "not_evaluated",
            "not_applicable",
            "complete",
            "partial",
            "blocked"
          ],
          "title": "Saved Look Coverage",
          "type": "string"
        },
        "source_files": {
          "items": {
            "type": "string"
          },
          "title": "Source Files",
          "type": "array"
        },
        "source_query_validation_status": {
